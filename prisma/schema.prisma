generator client {
  provider = "prisma-client"
  output   = "../.prisma/client/default"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String   @default("")
  avatarUrl    String?
  passwordHash String
  role         String   @default("USER")
  isActive     Boolean  @default(true)
  userGuideSeenAt DateTime?
  dialogueSessions DialogueSession[]
  dialogueAttempts DialogueAttempt[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([role])
  @@index([isActive])
}

model TrainingItem {
  id        String     @id @default(cuid())
  title     String
  audioUrl  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  sentences Sentence[]
}

model Sentence {
  id             String       @id @default(cuid())
  trainingItemId String
  trainingItem   TrainingItem @relation(fields: [trainingItemId], references: [id], onDelete: Cascade)
  text           String
  translation    String?
  startTime      Float
  endTime        Float
  order          Int
  userNotes      UserNote[]
}

model UserNote {
  id         String   @id @default(cuid())
  sentenceId String
  sentence   Sentence @relation(fields: [sentenceId], references: [id], onDelete: Cascade)
  words      String   @default("")
  notes      String   @default("")
  userId     String   @default("default")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([sentenceId, userId])
  @@index([sentenceId])
  @@index([userId])
}

model VideoTrainingItem {
  id          String            @id @default(cuid())
  title       String
  sourceTitle String            @default("")
  plotSummary String            @default("")
  tag         String
  mediaType   String            @default("video")
  mediaUrl    String
  coverUrl    String?
  coverPositionX Int            @default(50)
  coverPositionY Int            @default(50)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  captions    VideoCaption[]
  characters  VideoCharacter[]
  phraseNotes VideoPhraseNote[]

  @@index([createdAt])
  @@index([tag])
}

model VideoCaption {
  id                  String            @id @default(cuid())
  videoTrainingItemId String
  videoTrainingItem   VideoTrainingItem @relation(fields: [videoTrainingItemId], references: [id], onDelete: Cascade)
  startTime           Float
  endTime             Float
  enText              String
  zhText              String?
  speaker             String?
  isKeySentence       Boolean           @default(false)
  order               Int
  phraseNotes         VideoPhraseNote[]
  captionNotes        VideoCaptionNote[]

  @@index([videoTrainingItemId])
  @@index([videoTrainingItemId, order])
  @@index([speaker])
}

model VideoCharacter {
  id                  String            @id @default(cuid())
  videoTrainingItemId String
  videoTrainingItem   VideoTrainingItem @relation(fields: [videoTrainingItemId], references: [id], onDelete: Cascade)
  name                String
  avatarUrl           String?
  order               Int

  @@unique([videoTrainingItemId, name])
  @@index([videoTrainingItemId])
}

model VideoPhraseNote {
  id                  String            @id @default(cuid())
  videoTrainingItemId String
  videoTrainingItem   VideoTrainingItem @relation(fields: [videoTrainingItemId], references: [id], onDelete: Cascade)
  captionId           String?
  caption             VideoCaption?     @relation(fields: [captionId], references: [id], onDelete: SetNull)
  phrase              String
  note                String            @default("")
  userId              String            @default("default")
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([videoTrainingItemId])
  @@index([captionId])
  @@index([userId])
}

model VideoCaptionNote {
  id             String       @id @default(cuid())
  videoCaptionId String
  caption        VideoCaption @relation(fields: [videoCaptionId], references: [id], onDelete: Cascade)
  words          String       @default("")
  notes          String       @default("")
  userId         String       @default("default")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([videoCaptionId, userId])
  @@index([videoCaptionId])
  @@index([userId])
}

model LearningDailyStat {
  id               String   @id @default(cuid())
  userId           String   @default("default")
  dateKey          String
  studySeconds     Int      @default(0)
  audioSeconds     Int      @default(0)
  dictationSeconds Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, dateKey])
  @@index([userId])
  @@index([dateKey])
}

model DialogueScenario {
  id          String            @id @default(cuid())
  title       String
  description String            @default("")
  difficulty  String            @default("beginner")
  userRole    String            @default("")
  aiRole      String            @default("")
  tagsJson    String            @default("[]")
  coverUrl    String?
  isPublished Boolean           @default(false)
  startNodeId String?
  roleVoice   String            @default("marin")
  coachVoice  String            @default("cedar")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  nodes       DialogueNode[]
  edges       DialogueEdge[]
  sessions    DialogueSession[]

  @@index([isPublished])
  @@index([difficulty])
  @@index([createdAt])
}

model DialogueNode {
  id                   String              @id @default(cuid())
  scenarioId           String
  scenario             DialogueScenario    @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  order                Int
  title                String              @default("")
  roleLineEn           String
  roleLineZh           String?
  goal                 String
  rubricJson           String              @default("{}")
  hintJson             String              @default("{}")
  sampleAnswer         String              @default("")
  retryLimit           Int                 @default(2)
  allowDynamicFollowup Boolean             @default(false)
  positionX            Float               @default(0)
  positionY            Float               @default(0)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  outgoingEdges        DialogueEdge[]      @relation("DialogueEdgeFromNode")
  incomingEdges        DialogueEdge[]      @relation("DialogueEdgeToNode")
  sessions             DialogueSession[]   @relation("DialogueCurrentNode")
  attempts             DialogueAttempt[]

  @@index([scenarioId])
  @@index([scenarioId, order])
}

model DialogueEdge {
  id          String           @id @default(cuid())
  scenarioId  String
  scenario    DialogueScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  fromNodeId  String
  fromNode    DialogueNode     @relation("DialogueEdgeFromNode", fields: [fromNodeId], references: [id], onDelete: Cascade)
  onResult    String
  toNodeId    String?
  toNode      DialogueNode?    @relation("DialogueEdgeToNode", fields: [toNodeId], references: [id], onDelete: SetNull)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([fromNodeId, onResult])
  @@index([scenarioId])
  @@index([toNodeId])
}

model DialogueSession {
  id                 String             @id @default(cuid())
  scenarioId         String
  scenario           DialogueScenario   @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  userId             String
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentNodeId      String?
  currentNode        DialogueNode?      @relation("DialogueCurrentNode", fields: [currentNodeId], references: [id], onDelete: SetNull)
  status             String             @default("active")
  totalScore         Int                @default(0)
  completedNodeCount Int                @default(0)
  lastActivityAt     DateTime           @default(now())
  completedAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  attempts           DialogueAttempt[]

  @@index([scenarioId])
  @@index([userId])
  @@index([status])
  @@index([lastActivityAt])
}

model DialogueAttempt {
  id              String           @id @default(cuid())
  sessionId       String
  session         DialogueSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  scenarioId      String
  nodeId          String?
  node            DialogueNode?    @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  inputMode       String           @default("text")
  userText        String           @default("")
  transcriptText  String?
  routerIntent    String           @default("scene_answer")
  routerJson      String           @default("{}")
  evaluatorJson   String?
  coachJson       String?
  roleReplyEn     String?
  coachReplyZh    String?
  betterAnswerEn  String?
  passed          Boolean?
  score           Int?
  nextAction      String           @default("stay")
  createdAt       DateTime         @default(now())

  @@index([sessionId])
  @@index([scenarioId])
  @@index([nodeId])
  @@index([userId])
  @@index([createdAt])
}

model DialogueSpeechAsset {
  id           String   @id @default(cuid())
  cacheKey     String   @unique
  text         String
  voice        String
  model        String
  instructions String   @default("")
  audioUrl     String
  createdAt    DateTime @default(now())

  @@index([voice])
  @@index([createdAt])
}
